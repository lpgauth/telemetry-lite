{erl_opts, [debug_info]}.
{deps, []}.

{profiles, [
    {test, [
        {erl_opts, [nowarn_export_all]},
        {cover_enabled, true},
        {cover_opts, [verbose]}
    ]}
]}.

{shell, [{apps, [telemetry]}]}.

{xref_checks, [
    undefined_function_calls,
    undefined_functions,
    locals_not_used,
    deprecated_function_calls,
    deprecated_functions
]}.

{project_plugins, [erlfmt, rebar3_hex, rebar3_ex_doc]}.

{hex, [
    {doc, #{provider => ex_doc}}
]}.

{ex_doc, [
    {source_url, <<"https://github.com/lpgauth/telemetry-lite">>},
    {extras, [<<"LICENSE">>]},
    {main, <<"telemetry">>}
]}.
